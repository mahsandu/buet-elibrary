# ==============================================================================
# BUET E-Library V4 - Environment Variables Template
# Copy this file to .env and fill in your actual values before starting.
# ==============================================================================

# ------------------------------------------------------------------------------
# MariaDB Database
# ------------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_DATABASE=drupal
MYSQL_USER=drupal
MYSQL_PASSWORD=changeme_drupal

# ------------------------------------------------------------------------------
# Drupal Site Settings
# ------------------------------------------------------------------------------
DRUPAL_SITE_NAME=BUET E-Library
DRUPAL_ADMIN_USER=admin
DRUPAL_ADMIN_PASSWORD=changeme_admin
DRUPAL_ADMIN_EMAIL=admin@example.ac.bd

# ------------------------------------------------------------------------------
# Elasticsearch
# ------------------------------------------------------------------------------
ES_HOST=elasticsearch
ES_PORT=9200

# ------------------------------------------------------------------------------
# Redis (scraper cache)
# ------------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# ------------------------------------------------------------------------------
# OAI-PMH Harvester - Koha
# Koha must have OAI-PMH enabled. Set VERIFY_SSL=false for self-signed certs.
# ------------------------------------------------------------------------------
KOHA_OAI_URL=https://kopa.buet.ac.bd/cgi-bin/koha/oai.pl
VERIFY_SSL=false

# ------------------------------------------------------------------------------
# OAI-PMH Harvester - DSpace
# DSpace must have OAI-PMH enabled (usually at /oai/request).
# ------------------------------------------------------------------------------
DSPACE_OAI_URL=https://dspace.buet.ac.bd/oai/request

# ------------------------------------------------------------------------------
# Harvester Settings
# ------------------------------------------------------------------------------
HARVESTER_BATCH_SIZE=100
HARVESTER_SCHEDULE=*/30 * * * *
HARVESTER_FULLTEXT_ENABLED=true

# ------------------------------------------------------------------------------
# Microservice API
# ------------------------------------------------------------------------------
MICROSERVICE_HOST=microservices
MICROSERVICE_PORT=5000

# ------------------------------------------------------------------------------
# Security / SSL
# ------------------------------------------------------------------------------
# Set to false in development if using self-signed certificates.
# In production, always use true with valid CA-trusted certs.
SSL_VERIFY=true
